@page
@model ModeratorWeb.Pages.Players.IndexModel
@{ ViewData["Title"] = "Игроки"; Layout = "/Pages/Shared/_Layout.cshtml"; }

<h2>Игроки</h2>

<form method="get" style="margin-bottom:24px;">
    <input name="search" value="@Model.Search"
           placeholder="Поиск по username, email или ID..."
           style="width:100%; max-width:480px;" />
</form>

<table style="width:100%; border-collapse:collapse;">
    <thead>
        <tr>
            <th style="padding:12px 16px; text-align:left;">Username</th>
            <th style="padding:12px 16px; text-align:left; color:#7c6df0; font-size:13px;">Email</th>
            <th style="padding:12px 16px; text-align:left; color:#7c6df0; font-size:13px;">Роль</th>
            <th style="padding:12px 16px; text-align:left; color:#7c6df0; font-size:13px;">Статус</th>
            <th style="padding:12px 16px; text-align:left; color:#7c6df0; font-size:13px;">Действия</th>
        </tr>
    </thead>
    <tbody>
    @foreach (var u in Model.Users)
    {
        <tr style="border-bottom:1px solid #1a1c2a; cursor:pointer;"
            onclick="location.href='/Players/Detail?userId=@u.Id'">
            <td style="padding:12px 16px;">@u.Username</td>
            <td style="padding:12px 16px; font-size:13px;" class="text-muted-cell">@u.Email</td>
            <td style="padding:12px 16px;">
                <span style="color:@(u.Role == "Moderator" ? "#7c6df0" : "#a0a3b1")">
                    @u.Role
                </span>
            </td>
            <td style="padding:12px 16px;">
                @if (u.IsBlocked)
                { <span style="color:#ff6b6b; font-weight:500;">Заблокирован</span> }
                else
                { <span style="color:#4caf82; font-weight:500;">Активен</span> }
            </td>
            <td style="padding:12px 16px;" onclick="event.stopPropagation()">
                <form method="post"
                      asp-page-handler="@(u.IsBlocked ? "Unblock" : "Block")">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="userId" value="@u.Id" />
                    <button type="submit"
                            class="btn @(u.IsBlocked ? "btn-success" : "btn-danger")"
                            style="font-size:12px; padding:4px 12px;">
                        @(u.IsBlocked ? "Разблокировать" : "Заблокировать")
                    </button>
                </form>
            </td>
        </tr>
    }
    </tbody>
</table>

@if (!Model.Users.Any())
{
    <p style="color:#a0a3b1; margin-top:16px;">Ничего не найдено</p>
}
